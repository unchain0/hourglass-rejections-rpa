# =============================================================================
# Hourglass Rejeições RPA - Environment Configuration
# =============================================================================
# Copie este arquivo para .env e preencha os valores necessários
# NUNCA commit o arquivo .env (já está no .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# APLICAÇÃO - Configurações Gerais
# -----------------------------------------------------------------------------

# Modo debug (abre navegador visível para debugging)
# Valores: true | false
DEBUG=false

# Timezone para agendamento e timestamps
# Exemplo: America/Sao_Paulo, UTC, America/New_York
TZ=America/Sao_Paulo

# Diretório para salvar os arquivos de saída (JSON/CSV)
# Padrão: ./outputs
OUTPUT_DIR=./outputs

# Arquivo para persistência de cookies
# Padrão: ./cookies.json
COOKIE_FILE=./cookies.json

# URL do sistema Hourglass
# Padrão: https://app.hourglass-app.com/v2/page/app
HOURGLASS_URL=https://app.hourglass-app.com/v2/page/app

# -----------------------------------------------------------------------------
# AGENDAMENTO - Horários de execução (formato cron)
# -----------------------------------------------------------------------------

# Horário da análise da manhã (padrão: 9:00 AM)
# Formato: "0 9 * * *" (minuto hora dia-mês mês dia-semana)
SCHEDULE_MORNING=0 9 * * *

# Horário da análise da tarde (padrão: 5:00 PM)
SCHEDULE_EVENING=0 17 * * *

# Timeout para operações do browser (em segundos)
# Padrão: 300 (5 minutos)
TIMEOUT=300

# -----------------------------------------------------------------------------
# NOTIFICAÇÕES - Resend (Email)
# Documentação: https://resend.com/docs
# -----------------------------------------------------------------------------

# API Key do Resend (obrigatório para notificações por email)
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=re_sua_api_key_aqui

# Email remetente (deve ser um domínio verificado no Resend)
# Exemplo: notifications@seudominio.com
RESEND_FROM_EMAIL=notifications@seudominio.com

# Email destinatário para notificações
# Exemplo: admin@seudominio.com
RESEND_TO_EMAIL=admin@seudominio.com

# -----------------------------------------------------------------------------
# MONITORAMENTO DE ERROS - Sentry
# Documentação: https://docs.sentry.io/platforms/go/
# -----------------------------------------------------------------------------

# DSN do Sentry (obrigatório para rastreamento de erros)
# Obtenha em: Configurações do Projeto → Client Keys (DSN)
SENTRY_DSN=https://seu_dsn_aqui@sentry.io/projeto

# Ambiente do Sentry (opcional)
# Valores: development | staging | production
SENTRY_ENVIRONMENT=production

# Release/version para tracking no Sentry (opcional)
SENTRY_RELEASE=1.0.0

# -----------------------------------------------------------------------------
# MÉTRICAS - Grafana Cloud
# Documentação: https://grafana.com/docs/grafana-cloud/
# -----------------------------------------------------------------------------

# Habilitar envio de métricas para Grafana Cloud
# Valores: true | false
GRAFANA_ENABLED=false

# URL do endpoint Prometheus do Grafana Cloud
# Formato: https://prometheus-prod-XX-grafana.grafana.net/api/prom/push
GRAFANA_ENDPOINT=https://prometheus-prod-XX-grafana.grafana.net/api/prom/push

# API Key do Grafana Cloud
# Obtenha em: Grafana Cloud → Security → API Keys
GRAFANA_API_KEY=glc_sua_api_key_aqui

# Usuário do Grafana Cloud (normalmente é um número)
GRAFANA_USER=123456

# -----------------------------------------------------------------------------
# LOGGING - Configurações de Log
# -----------------------------------------------------------------------------

# Nível de log
# Valores: debug | info | warn | error
LOG_LEVEL=info

# Formato do log
# Valores: pretty (colorido para terminal) | text | json
LOG_FORMAT=pretty

# Arquivo de log (opcional - se não definido, usa stdout)
# Exemplo: ./logs/rpa.log
LOG_FILE=

# Desabilitar cores no log (útil quando redireciona para arquivo)
# Valores: true | false
LOG_NO_COLOR=false

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES AVANÇADAS
# -----------------------------------------------------------------------------

# Tamanho máximo do arquivo de log em MB (antes de rotacionar)
LOG_MAX_SIZE=10

# Número máximo de arquivos de log antigos para manter
LOG_MAX_BACKUPS=3

# Número máximo de dias para manter arquivos de log antigos
LOG_MAX_AGE=7

# Comprimir arquivos de log antigos
# Valores: true | false
LOG_COMPRESS=true

# Binário do Chrome/Chromium (deixe em branco para usar o padrão do sistema)
# Exemplo: /usr/bin/google-chrome ou /usr/bin/chromium-browser
CHROME_BIN=

# Modo headless do Chrome
# Valores: true (invisível) | false (visível, útil para debug)
CHROME_HEADLESS=true

# =============================================================================
# EXEMPLO DE CONFIGURAÇÃO MÍNIMA PARA DESENVOLVIMENTO
# =============================================================================
# Para desenvolvimento local, você só precisa de:
#
# DEBUG=true
# LOG_LEVEL=debug
# LOG_FORMAT=pretty
# OUTPUT_DIR=./outputs
# COOKIE_FILE=./cookies.json
#
# As notificações (Resend, Sentry, Grafana) são opcionais para desenvolvimento
# =============================================================================
