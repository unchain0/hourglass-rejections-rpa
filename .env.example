# Hourglass Rejections RPA - Environment Configuration
# Copy to .env and fill required values (never commit .env)

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# Telegram Bot Configuration
# Get token from @BotFather: https://t.me/botfather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Whitelist of users who can receive notifications
# Comma-separated list of Telegram chat IDs (get from @userinfobot)
TELEGRAM_WHITELIST=123456789,987654321

# =============================================================================
# TOKEN CONFIGURATION (VPS/Server Deployment)
# =============================================================================

# Option 1: Manual token configuration (copy from browser DevTools)
# Get from: Hourglass → DevTools → Network → Request Headers
HOURGLASS_XSRF_TOKEN=your_token_here
HOURGLASS_HGLOGIN_COOKIE=your_cookie_here

# Option 2: Token file path (recommended for VPS)
# Tokens saved via 'make save-tokens' will be stored here
TOKENS_PATH=/home/user/.hourglass-rpa/auth-tokens.json

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

# API endpoint (default: https://app.hourglass-app.com)
# HOURGLASS_URL=https://app.hourglass-app.com

# Output directory for results (default: ./outputs)
OUTPUT_DIR=./outputs

# SQLite database path (default: data/hourglass.db)
# SQLITE_DB_PATH=data/hourglass.db

# Timezone (default: America/Sao_Paulo)
TZ=America/Sao_Paulo

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# =============================================================================
# ADVANCED: Token Refresh Configuration
# =============================================================================

# Enable automatic token refresh (default: true)
# AUTO_REFRESH_TOKENS=true

# Refresh interval (default: 6h)
# REFRESH_INTERVAL=6h

# =============================================================================
# MONITORING (Optional)
# =============================================================================

# Sentry error tracking
# SENTRY_DSN=https://your_dsn@sentry.io/project
# SENTRY_ENVIRONMENT=production

# Grafana metrics
# GRAFANA_API_KEY=your_api_key
