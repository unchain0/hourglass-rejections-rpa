# Hourglass Rejections RPA - Environment Configuration
# Copy to .env and fill required values (never commit .env)

# Required: XSRF Token from Hourglass
# Get it from: Hourglass → DevTools → Network → X-Hourglass-XSRF-Token header
HOURGLASS_XSRF_TOKEN=your_token_here

# Required: HGLogin Cookie from Hourglass
# Get it from: Hourglass → DevTools → Application → Cookies → hglogin
HOURGLASS_HGLOGIN_COOKIE=your_cookie_here

# Optional: Hourglass credentials for Playwright mode (fallback if tokens expire)
HOURGLASS_EMAIL=your_email@example.com
HOURGLASS_PASSWORD=your_password

# Optional: API endpoint (default: https://app.hourglass-app.com)
# HOURGLASS_URL=https://app.hourglass-app.com

# Optional: Output directory for results (default: ./outputs)
OUTPUT_DIR=./outputs

# Optional: Use JSON instead of SQLite for user preferences (default: false)
# USE_JSON=false

# Optional: User preferences file path (default: data/preferences.json)
# USER_PREFS_FILE=data/preferences.json

# Optional: SQLite database path (default: data/hourglass.db)
# SQLITE_DB_PATH=data/hourglass.db

# Optional: Cookie file for session persistence (default: cookies.json)
# COOKIE_FILE=cookies.json

# Optional: Enable debug logging (default: false)
# DEBUG=false

# Optional: Schedule cron expressions (default: 9 AM and 5 PM)
# SCHEDULE_MORNING=0 9 * * *
# SCHEDULE_EVENING=0 17 * * *

# Optional: Request timeout (default: 60s)
# TIMEOUT=60s

# Optional: Sentry error tracking
# SENTRY_DSN=https://your_dsn@sentry.io/project
# SENTRY_ENVIRONMENT=production

# Optional: Timezone (default: America/Sao_Paulo)
TZ=America/Sao_Paulo

# Optional: Log level (default: info)
LOG_LEVEL=info
