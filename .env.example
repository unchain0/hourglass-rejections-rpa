# =============================================================================
# Hourglass Rejeições RPA - Environment Configuration
# =============================================================================
# Copie este arquivo para .env e preencha os valores necessários
# NUNCA commit o arquivo .env (já está no .gitignore)
# =============================================================================

# =============================================================================
# HOURGLASS API - AUTENTICAÇÃO (OBRIGATÓRIO)
# =============================================================================

# XSRF Token para autenticação na API do Hourglass
# 
# COMO OBTER:
# 1. Faça login no Hourglass pelo navegador (https://app.hourglass-app.com)
# 2. Abra o DevTools (pressione F12)
# 3. Vá para a aba "Network" (Rede)
# 4. Faça qualquer ação no sistema (ex: carregar designações)
# 5. Procure uma requisição que comece com "api/v0.2/"
# 6. Clique na requisição e procure o header: "X-Hourglass-XSRF-Token"
# 7. Copie o valor (exemplo: KizSvAQQ4B6lCkHNGagusFtX5nRjlbVZ)
#
# NOTA: O token expira após algum tempo. Se as requisições falharem com 401,
# você precisará obter um novo token repetindo o processo acima.
#
HOURGLASS_XSRF_TOKEN=seu_token_aqui

# ID da congregação (opcional - padrão: 48092)
# Apenas altere se souber o ID específico da sua congregação
HOURGLASS_CONGREGATION_ID=48092

# =============================================================================
# NOTIFICAÇÕES - Resend (Email) (OPCIONAL mas recomendado)
# =============================================================================

# API Key do Resend para envio de emails
# 
# COMO OBTER:
# 1. Acesse https://resend.com e crie uma conta
# 2. Vá para "API Keys" no menu lateral
# 3. Clique em "Create API Key"
# 4. Dê um nome (ex: "Hourglass RPA") e copie a chave
# 5. A chave começa com "re_" (exemplo: re_xxxxxxxx)
#
# Documentação: https://resend.com/docs
#
RESEND_API_KEY=re_sua_api_key_aqui

# Email remetente (deve ser um domínio verificado no Resend)
# 
# COMO CONFIGURAR:
# 1. No Resend, vá para "Domains"
# 2. Adicione e verifique seu domínio (ex: seudominio.com)
# 3. O email deve usar esse domínio
#
RESEND_FROM_EMAIL=notifications@seudominio.com

# Email destinatário para receber notificações de rejeições
# Pode ser seu email pessoal ou de um grupo
RESEND_TO_EMAIL=admin@seudominio.com

# =============================================================================
# MONITORAMENTO DE ERROS - Sentry (OPCIONAL mas recomendado)
# =============================================================================

# DSN do Sentry para rastreamento de erros
#
# COMO OBTER:
# 1. Acesse https://sentry.io e crie uma conta
# 2. Crie um novo projeto (tipo: Go)
# 3. Na página de configuração do projeto, copie o DSN
# 4. O DSN tem formato: https://xxxxxx@xxx.ingest.sentry.io/xxxxx
#
# Documentação: https://docs.sentry.io/platforms/go/
#
SENTRY_DSN=https://seu_dsn_aqui@sentry.io/projeto

# Ambiente do Sentry (opcional)
# Valores: development | staging | production
SENTRY_ENVIRONMENT=production

# =============================================================================
# MÉTRICAS - Grafana Cloud (OPCIONAL)
# =============================================================================

# API Key do Grafana Cloud para métricas
#
# COMO OBTER:
# 1. Acesse https://grafana.com e faça login
# 2. Vá para seu Grafana Cloud instance
# 3. Clique no menu do usuário (canto superior direito) → "API Keys"
# 4. Crie uma nova API Key com papel "MetricsPublisher"
# 5. A chave começa com "glc_" (exemplo: glc_xxxxxxxx)
#
# Documentação: https://grafana.com/docs/grafana-cloud/
#
GRAFANA_API_KEY=glc_sua_api_key_aqui

# =============================================================================
# CONFIGURAÇÕES GERAIS (OPCIONAIS)
# =============================================================================

# Nível de log
# Valores: debug | info | warn | error
# debug: mostra todas as requisições e respostas da API
LOG_LEVEL=info

# Diretório para salvar os arquivos de saída (JSON/CSV)
OUTPUT_DIR=./outputs

# Timezone para agendamento e timestamps
# Exemplo: America/Sao_Paulo, UTC, America/New_York
TZ=America/Sao_Paulo

# =============================================================================
# EXEMPLO DE CONFIGURAÇÃO MÍNIMA
# =============================================================================
# Para rodar a aplicação, você precisa apenas do XSRF Token:
#
# HOURGLASS_XSRF_TOKEN=KizSvAQQ4B6lCkHNGagusFtX5nRjlbVZ
#
# Todas as outras configurações são opcionais mas recomendadas
# para monitoramento completo.
# =============================================================================
